datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id          Int      @id @default(autoincrement())
  telegramId  BigInt   @unique
  username    String?
  subscriptions Subscription[]
  payments    Payment[]
  createdAt   DateTime @default(now())

  @@index([telegramId])
}

model Plan {
  id       Int    @id @default(autoincrement())
  name     String @unique
  price    Int
  duration Int // days

  subscriptions Subscription[]
  payments      Payment[]
}

model Subscription {
  id          Int      @id @default(autoincrement())
  userId      Int
  planId      Int
  status      String   @default("active")
  startAt     DateTime @default(now())
  endAt       DateTime
  xuiClientId String?
  /// subId, который выдается пользователю как часть ссылки /sub/{subId}
  subId       String?  @unique
  /// email клиента в X-UI (нужен для корректного удаления)
  xuiEmail    String?

  user User @relation(fields: [userId], references: [id])
  plan Plan @relation(fields: [planId], references: [id])

  @@index([userId, status])
  @@index([status, endAt])
}

model Payment {
  id          Int      @id @default(autoincrement())
  userId      Int
  planId      Int
  invoiceId   String   @unique
  status      String   @default("pending")
  amount      Int
  orderId     String   @unique
  description String?
  payUrl      String?
  payTime     DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
  plan Plan @relation(fields: [planId], references: [id])

  @@index([invoiceId])
  @@index([orderId])
  @@index([status])
  @@index([userId])
}
