{
  "name": "vpn-bot",
  "version": "1.0.0",
  "description": "Telegram-бот для продажи VPN-подписок через X-UI и Lava.Top",
  "main": "dist/src/main.js",
  "scripts": {
    "start": "node dist/src/main.js",
    "build": "tsc",
    "dev": "ts-node src/main.ts",
    "setup": "ts-node scripts/setup.ts",
    "seed": "ts-node scripts/seed.ts",
    "prisma:check": "ts-node scripts/check-prisma.ts",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:generate": "prisma generate"
  },
  "keywords": [
    "telegram-bot",
    "vpn",
    "x-ui",
    "lava-top",
    "prisma"
  ],
  "author": "",
  "license": "MIT",
  "packageManager": "pnpm@10.24.0",
  "dependencies": {
    "@prisma/client": "6",
    "axios": "^1.13.3",
    "dotenv": "^17.2.3",
    "lava-top-sdk": "^1.0.1",
    "prisma": "6",
    "telegraf": "^4.16.3"
  },
  "devDependencies": {
    "@types/node": "^25.0.10",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
}
